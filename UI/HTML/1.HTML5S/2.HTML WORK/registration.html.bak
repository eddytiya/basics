<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Registration</title>
</head>
<body>
<center><h2>Registration</h2></center>
    <center>
 <table>
 <form method="post" action="login.html">
	
 <tr>
	<td>name:</td>
	<td><input type="name"></td>
 </tr>
 <tr>
	<td>phone:</td>
	<td><input type="number"></td>
 </tr>
 <tr>
	<td>email:</td>
	<td><input type="email"></td>
 </tr>
 <tr>
	<td>userid</td>
	<td><input type="userid"></td>
 </tr>
 <tr>
	<td>password:</td>
	<td><input type="password"></td>
 </tr>
 <tr>
	<td><input type="submit" value="submit" onclick="login.html"></td>
	<td><input type="reset" value="reset" onclick="home.html"></td>
 </tr>
 </table>
 </form>
 </center>
 


 </body>

</body>
</html>
